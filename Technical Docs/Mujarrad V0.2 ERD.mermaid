erDiagram
    %% =====================================================
    %% MUJARRAD V0.2 - PRODUCTION-READY ERD (Multi-Tenant)
    %% Architecture: "Everything is a Node" + Multi-Tenancy
    %% Updated: 2025-10-05 (Added Workspaces, Fixed NodeDetails)
    %% =====================================================

    %% Multi-Tenancy Tables (NEW)
    WORKSPACES {
        uuid id PK
        string name "NOT NULL"
        string slug UK "NOT NULL, CHECK slug pattern"
        timestamp created_at "DEFAULT CURRENT_TIMESTAMP"
        timestamp updated_at "DEFAULT CURRENT_TIMESTAMP"
    }

    WORKSPACE_USERS {
        uuid id PK
        uuid workspace_id FK "REFERENCES WORKSPACES ON DELETE CASCADE"
        uuid user_id FK "REFERENCES USERS ON DELETE CASCADE"
        string role "CHECK IN OWNER, ADMIN, MEMBER, VIEWER"
        timestamp joined_at "DEFAULT CURRENT_TIMESTAMP"
        string UNIQUE_workspace_user "UNIQUE(workspace_id, user_id)"
    }

    %% Core Tables
    USERS {
        uuid id PK
        string email UK "NOT NULL, CHECK email format"
        string name "NOT NULL"
        string role "CHECK IN developer, editor, viewer, admin"
        timestamp created_at "DEFAULT CURRENT_TIMESTAMP"
        timestamp updated_at "DEFAULT CURRENT_TIMESTAMP"
        boolean is_active "DEFAULT true"
    }

    NODES {
        uuid id PK
        uuid workspace_id FK "REFERENCES WORKSPACES ON DELETE CASCADE"
        string node_type "CHECK IN REGULAR, CONTEXT, ASSUMPTION"
        string title "NOT NULL"
        string slug UK "NOT NULL, CHECK slug pattern, workspace-scoped"
        text description
        text markdown_content
        jsonb node_details "GIN indexed, replaces NODE_DETAILS table"
        uuid creator_id FK "REFERENCES USERS ON DELETE RESTRICT"
        uuid current_version_id FK
        integer version "DEFAULT 1, for optimistic locking"
        timestamp created_at
        timestamp updated_at
    }

    NODE_VERSIONS {
        uuid id PK
        uuid node_id FK "REFERENCES NODES ON DELETE CASCADE"
        integer version_number "NOT NULL"
        text markdown_content
        jsonb metadata
        uuid created_by FK "REFERENCES USERS"
        timestamp created_at
        string UNIQUE_node_version "UNIQUE(node_id, version_number)"
    }

    ATTRIBUTES {
        uuid id PK
        uuid workspace_id FK "REFERENCES WORKSPACES ON DELETE CASCADE"
        uuid source_node_id FK "REFERENCES NODES, CHECK source != target"
        uuid target_node_id FK "REFERENCES NODES"
        string attribute_name "NOT NULL"
        string attribute_type "e.g., contains, priority, custom"
        string attribute_type_mode "CHECK IN TYPED, SCHEMALESS"
        string attribute_data_type "CHECK IN NUMBER, STRING, BOOLEAN, ENUM, JSON"
        jsonb attribute_value
        boolean is_bidirectional "DEFAULT false"
        decimal strength_weight "CHECK 0.0 to 1.0"
        jsonb properties
        timestamp created_at
        timestamp updated_at
    }

    MAPPINGS {
        uuid id PK
        uuid workspace_id FK "REFERENCES WORKSPACES ON DELETE CASCADE"
        uuid node_id FK UK "REFERENCES NODES ON DELETE CASCADE"
        string ordering_strategy "CHECK IN manual, alphabetical, chronological, custom"
        boolean allow_duplicates "DEFAULT false"
        jsonb configuration
        timestamp created_at
        timestamp updated_at
    }

    NODE_MAPPINGS {
        uuid id PK
        uuid mapping_node_id FK "REFERENCES NODES"
        uuid contained_node_id FK "REFERENCES NODES"
        integer sort_order "NOT NULL, CHECK > 0"
        jsonb metadata
        timestamp created_at
        timestamp updated_at
        string UNIQUE_mapping_node "UNIQUE(mapping_node_id, contained_node_id)"
    }

    CONDITIONALS {
        uuid id PK
        uuid workspace_id FK "REFERENCES WORKSPACES ON DELETE CASCADE"
        uuid node_id FK UK "REFERENCES NODES ON DELETE CASCADE"
        uuid preceding_node_id FK "REFERENCES NODES"
        uuid default_target_id FK "REFERENCES NODES ON DELETE SET NULL"
        text evaluation_logic
        timestamp created_at
        timestamp updated_at
    }

    CONDITIONAL_TARGETS {
        uuid id PK
        uuid conditional_node_id FK "REFERENCES NODES"
        uuid target_node_id FK "REFERENCES NODES"
        jsonb conditions
        integer priority "DEFAULT 0"
        timestamp created_at
        string UNIQUE_conditional_target "UNIQUE(conditional_node_id, target_node_id)"
    }

    AUDIT_LOG {
        uuid id PK
        uuid entity_id "NOT NULL"
        string entity_type "NOT NULL, CHECK IN node, attribute, mapping, conditional, user, workspace"
        string operation "CHECK IN CREATE, UPDATE, DELETE, RESTORE"
        uuid performed_by FK "REFERENCES USERS"
        jsonb before_value
        jsonb after_value
        timestamp created_at "DEFAULT CURRENT_TIMESTAMP"
    }

    SEARCH_INDEX {
        uuid id PK
        uuid workspace_id FK "REFERENCES WORKSPACES ON DELETE CASCADE"
        uuid node_id FK UK "REFERENCES NODES ON DELETE CASCADE"
        tsvector search_vector "GIN indexed"
        text[] keywords
        jsonb metadata
        timestamp last_indexed
    }

    %% =====================================================
    %% RELATIONSHIPS
    %% =====================================================

    %% Multi-Tenancy Relationships (NEW)
    WORKSPACES ||--o{ WORKSPACE_USERS : has_members
    USERS ||--o{ WORKSPACE_USERS : member_of
    WORKSPACES ||--o{ NODES : contains_nodes
    WORKSPACES ||--o{ ATTRIBUTES : scopes_attributes
    WORKSPACES ||--o{ MAPPINGS : scopes_mappings
    WORKSPACES ||--o{ CONDITIONALS : scopes_conditionals
    WORKSPACES ||--o{ SEARCH_INDEX : scopes_search

    %% User Relationships
    USERS ||--o{ NODES : creates
    USERS ||--o{ NODE_VERSIONS : creates_version
    USERS ||--o{ AUDIT_LOG : performs_action

    %% Node Core Relationships
    NODES ||--o{ NODE_VERSIONS : has_versions
    NODES ||--|| NODE_VERSIONS : current_version
    NODES ||--o| SEARCH_INDEX : indexed_for_search

    %% Attribute Relationships (Node-to-Node connections)
    NODES ||--o{ ATTRIBUTES : source_attribute
    NODES ||--o{ ATTRIBUTES : target_attribute

    %% Mapping Relationships (Collections)
    NODES ||--o{ MAPPINGS : has_mapping
    NODES ||--o{ NODE_MAPPINGS : mapping_container
    NODES ||--o{ NODE_MAPPINGS : contained_in

    %% Conditional Relationships (Logic/Routing)
    NODES ||--o{ CONDITIONALS : has_conditional
    NODES ||--o{ CONDITIONAL_TARGETS : conditional_source
    NODES ||--o{ CONDITIONAL_TARGETS : conditional_target

    %% =====================================================
    %% ARCHITECTURE NOTES
    %% =====================================================
    %%
    %% MULTI-TENANCY (NEW IN V0.2):
    %% - All data scoped to workspaces via workspace_id foreign keys
    %% - Workspace access controlled via WORKSPACE_USERS join table
    %% - Roles: OWNER, ADMIN, MEMBER, VIEWER
    %% - Slug-based routing: /api/workspaces/{slug}/...
    %%
    %% NODE_DETAILS REMOVED:
    %% - NODE_DETAILS table removed in favor of node_details JSONB column in NODES
    %% - More flexible, avoids extra join, enables GIN indexing
    %% - Stores: tags[], is_template, template_id, metadata
    %%
    %% NODE_TYPE ENUM UPDATED:
    %% - Changed from: node, attribute, mapping, conditional, context
    %% - Changed to: REGULAR, CONTEXT, ASSUMPTION
    %% - Better semantic naming for user-facing types
    %%
    %% CONTEXTS ARE NODES:
    %% - Contexts are nodes with node_type = 'CONTEXT'
    %% - Containment via ATTRIBUTES with attribute_type = 'contains'
    %% - Multi-context membership = multiple 'contains' relationships
    %%
    %% TEMPLATES ARE NODES:
    %% - Templates are nodes with node_details.is_template = true
    %% - No separate TEMPLATES table needed
    %%
    %% ATTRIBUTES ENHANCED:
    %% - Dual-mode system: TYPED (validated) vs SCHEMALESS (flexible)
    %% - Supports both relationships (target_node_id) and scalar values (attribute_value)
    %% - Custom attribute types (user-defined strings)
    %%
    %% RELATIONSHIPS:
    %% - All node-to-node connections via ATTRIBUTES table
    %% - Common types: contains, depends_on, references, parent_of, relates_to
    %% - Custom types supported
    %%
    %% COLLECTIONS:
    %% - Use MAPPINGS for ordered collections
    %% - Supports multiple ordering strategies
    %%
    %% CONDITIONALS:
    %% - Workflow/routing logic feature
    %% - Enables if-then behavior in graph
    %%
    %% CYCLE DETECTION:
    %% - Context → Node CONTAINS: Cycles FORBIDDEN (UI breadcrumbs)
    %% - Node → Node CONTAINS: Cycles ALLOWED (recursive data)
    %% - All non-CONTAINS: Cycles ALLOWED (Abstract Logic)
    %%
    %% =====================================================
    %% CHANGES FROM V0.1:
    %% =====================================================
    %% 1. Added WORKSPACES table (multi-tenancy)
    %% 2. Added WORKSPACE_USERS table (role-based access)
    %% 3. Removed NODE_DETAILS table (now JSONB column in NODES)
    %% 4. Updated NODE_TYPE enum (REGULAR/CONTEXT/ASSUMPTION)
    %% 5. Added workspace_id FK to all tenant-scoped tables
    %% 6. Enhanced ATTRIBUTES with dual-mode system
    %% 7. Added workspace to AUDIT_LOG entity_type
    %% =====================================================
